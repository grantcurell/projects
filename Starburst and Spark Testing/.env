COMPOSE_PROJECT_NAME=spark_trino_schema_demo

TRINO_IMAGE=trinodb/trino:481
SPARK_IMAGE=apache/spark:4.1.2
POSTGRES_IMAGE=postgres:16
MYSQL_IMAGE=mysql:8.4

TRINO_CLIENT_VERSION=481
POSTGRES_JDBC_VERSION=42.7.11

DEMO_DB_USER=demo
DEMO_DB_PASSWORD=demo_password

CRM_POSTGRES_DB=crm
GOVERNED_POSTGRES_DB=governed
MYSQL_APP_DB=appdb

TRINO_HOST_PORT=8080
SPARK_MASTER_UI_PORT=8081
SPARK_WORKER_UI_PORT=8082
CRM_POSTGRES_HOST_PORT=15432
GOVERNED_POSTGRES_HOST_PORT=15433
MYSQL_HOST_PORT=13306
