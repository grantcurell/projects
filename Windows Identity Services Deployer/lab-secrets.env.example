# Copy to lab-secrets.env, fill in values, and never commit lab-secrets.env.
# Load before running lab harnesses:
#   set -a && source lab-secrets.env && set +a
#
# WIS_LAB_WINRM_PASSWORD — local Administrator (pre-promotion) / domain admin (post)
# WIS_LAB_DSRM_PASSWORD — Directory Services Restore Mode password for forest install
# WIS_LAB_SERVICEACCOUNT_PASSWORD — prompted service-account password used during PostPromotion

WIS_LAB_WINRM_PASSWORD=
WIS_LAB_DSRM_PASSWORD=
WIS_LAB_SERVICEACCOUNT_PASSWORD=

# Optional overrides (defaults are fine for the standard lab layout):
# WIS_LAB_WINRM_HOST=192.168.5.10
# WIS_LAB_WINRM_USER=Administrator
# WIS_LAB_NETBIOS_NAME=IDENTITY
# WIS_LAB_DOMAIN_DNS=identity.lab.example.com
