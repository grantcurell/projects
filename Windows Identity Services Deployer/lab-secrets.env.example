# Copy this file to lab-secrets.env (same directory), fill in values, and never commit
# lab-secrets.env. All Python lab harnesses and the config wizard load it automatically.

# Required — WinRM (local Administrator pre-promotion; domain admin post-promotion)
WIS_LAB_WINRM_PASSWORD=

# Required — passed to the deployer during forest promotion and service-account creation
WIS_LAB_DSRM_PASSWORD=
WIS_LAB_SERVICEACCOUNT_PASSWORD=

# Optional lab topology overrides (defaults match baseline.yaml)
# WIS_LAB_WINRM_HOST=192.168.5.10
# WIS_LAB_WINRM_FALLBACK_HOST=192.168.5.171
# WIS_LAB_WINRM_USER=Administrator
# WIS_LAB_NETBIOS_NAME=IDENTITY
# WIS_LAB_DOMAIN_DNS=identity.lab.example.com
# WIS_LAB_MAX_WAIT_MINUTES=120
